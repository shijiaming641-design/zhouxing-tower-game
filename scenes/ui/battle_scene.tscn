[gd_scene format=3]

[node name="BattleScene" type="Control"]
layout_mode = 3
anchors_preset = 15
grow_horizontal = 2
grow_vertical = 2

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
grow_horizontal = 2
grow_vertical = 2
color = Color(0.85, 0.85, 0.8, 1)

[node name="EnemyPanel" type="Control" parent="."]
layout_mode = 0
offset_left = 1000.0
offset_top = 30.0
offset_right = 1250.0
offset_bottom = 150.0

[node name="Title" type="Label" parent="EnemyPanel"]
layout_mode = 0
offset_right = 100.0
offset_bottom = 30.0
theme_override_font_sizes/font_size = 20
text = "👹 敌方"
modulate = Color(0, 0, 0, 1)

[node name="HPLabel" type="Label" parent="EnemyPanel"]
layout_mode = 0
offset_top = 25.0
offset_right = 200.0
offset_bottom = 50.0
theme_override_font_sizes/font_size = 18
text = "💚💚💚💚💚💚💚💚 8/8"
modulate = Color(0, 0, 0, 1)

